{
  "description": "Privately capture submitted prompts for the local writing voice profile.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-prompt.sh plugin",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
